{
  "version": 2,
  "rewrites": [
    { "source": "/styles/(.*)", "destination": "/frontend/styles/$1" },
    { "source": "/scripts/(.*)", "destination": "/frontend/scripts/$1" },
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" },
    { "source": "/", "destination": "/frontend/pages/index.html" }
  ]
}
